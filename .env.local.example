# ─── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://user:password@host/nexus-os?sslmode=require"

# ─── Clerk ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Paystack ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# ─── IntaSend (M-Pesa) ────────────────────────────────────────
INTASEND_API_KEY=ISPubKey_test_xxxx

# ─── UploadThing ──────────────────────────────────────────────
UPLOADTHING_SECRET=sk_live_xxxx
UPLOADTHING_APP_ID=xxxx

# ─── Resend ───────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
